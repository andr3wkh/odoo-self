# ── PostgreSQL ──
POSTGRES_DB=postgres
POSTGRES_USER=odoo
POSTGRES_PASSWORD=CHANGE_ME

# ── Odoo ──
ODOO_ADMIN_PASSWD=CHANGE_ME
ODOO_DB_HOST=db
ODOO_DB_PORT=5432
ODOO_DB_USER=odoo
ODOO_DB_PASSWORD=CHANGE_ME
ODOO_DB_NAME=False

# ── Source Odoo (for migration only) ──
SRC_ODOO_URL=https://your-instance.odoo.com
SRC_ODOO_DB=your_db
SRC_ODOO_USER=your_user@example.com
SRC_ODOO_PASSWORD=your_api_key

# ── Local Odoo ──
DST_ODOO_URL=http://localhost:8069
DST_ODOO_DB=odoo18
DST_ODOO_USER=admin
DST_ODOO_PASSWORD=CHANGE_ME
